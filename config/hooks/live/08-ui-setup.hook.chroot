#!/bin/bash
echo "==> Setting up Rune OS Theme & Icons..."

# Ensure apt lists are updated before installing git to prevent silent crashes
apt-get update || true
apt-get install -y git || true

# Install WhiteSur Icons safely
git clone https://github.com/vinceliuice/WhiteSur-icon-theme.git /tmp/whitesur-icons || true
if [ -d "/tmp/whitesur-icons" ]; then
    /tmp/whitesur-icons/install.sh -a -d /usr/share/icons || true
    rm -rf /tmp/whitesur-icons
fi

# Force Wallpaper globally
if [ -f /usr/share/backgrounds/rune-wallpaper.svg ]; then
    mkdir -p /usr/share/wallpapers/Next/contents/images/
    ln -sf /usr/share/backgrounds/rune-wallpaper.svg /usr/share/wallpapers/Next/contents/images/1920x1080.png
    ln -sf /usr/share/backgrounds/rune-wallpaper.svg /usr/share/wallpapers/Next/contents/images/2560x1440.png
    ln -sf /usr/share/backgrounds/rune-wallpaper.svg /usr/share/wallpapers/Next/contents/images/3840x2160.png
    mkdir -p /usr/share/sddm/themes/breeze/
    ln -sf /usr/share/backgrounds/rune-wallpaper.svg /usr/share/sddm/themes/breeze/background.png || true
fi
